# GitHub Pages configuration
# This file ensures proper handling of the site

# Treat images as binary
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.webp binary
*.mp3 binary
*.mp4 binary
*.ogg binary

# Ensure proper line endings for text files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.py text eol=lf
*.sh text eol=lf
